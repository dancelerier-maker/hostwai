# Required — your Anthropic API key (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Optional — phone number to transfer calls to, in E.164 format (e.g. +33612345678).
# If empty, the agent apologizes and asks the caller to call back instead of transferring.
STAFF_PHONE_NUMBER=

# Required for SMS confirmations (to the caller) and staff notifications.
# Find these in your Twilio console (console.twilio.com).
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+33...

# Required for the paid subscription flow (Stripe)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID_STARTER=price_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_APP_URL=https://ton-domaine.vercel.app
